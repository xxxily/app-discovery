{
  "name": "app-discovery",
  "version": "1.0.0",
  "description": "全平台优质应用探索与发现枢纽，致力于搜罗高质量应用及其开源替代品。",
  "keywords": [
    "App",
    "Discovery",
    "Open Source",
    "Alternatives",
    "Windows",
    "macOS",
    "Android",
    "iOS",
    "Linux",
    "Automation",
    "AI Agent",
    "App-Discovery"
  ],
  "type": "module",
  "files": [
    "assets",
    "docs",
    "home",
    "dist",
    "src",
    "logo.png"
  ],
  "author": "Blaze",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "homepage": "https://app-discovery.anzz.top",
  "repository": {
    "type": "git",
    "url": "https://github.com/xxxily/app-discovery"
  },
  "bugs": {
    "url": "https://github.com/xxxily/app-discovery/issues"
  },
  "license": "MIT",
  "main": "src/index.js",
  "module": "src/index.js",
  "unpkg": "src/index.js",
  "scripts": {
    "docs:dev": "vitepress dev ./",
    "docs:build": "vitepress build ./",
    "docs:preview": "vitepress preview ./",
    "ai:extract-categories": "node scripts/extract-categories.js",
    "ai:discover-eval": "node scripts/discover-and-evaluate.js",
    "ai:update-status": "node scripts/update-status.js",
    "ai:generate-docs": "node scripts/generate-docs.js",
    "ai:loop-eval": "node scripts/loop-eval.js",
    "ai:loop-eval-tui": "node scripts/loop-eval.js --tui",
    "ai:re-evaluate-all": "node scripts/re-evaluate-all.js",
    "ai:consume-queue": "node scripts/loop-eval.js --consume-only",
    "ai:analyze-topics": "node scripts/analyze-topics.js",
    "ai:analyze-rejected": "node scripts/analyze-rejected.js",
    "publish": "bash scripts/publish.sh"
  },
  "devDependencies": {
    "@babel/core": "^7.20.2",
    "@babel/plugin-transform-runtime": "^7.19.6",
    "@babel/preset-env": "^7.20.2",
    "@playwright/test": "^1.28.1",
    "@rollup/plugin-babel": "^6.0.2",
    "@vitejs/plugin-legacy": "^2.3.1",
    "typescript": "^4.9.3",
    "vite": "^8.0.1",
    "vite-plugin-babel": "^1.1.2",
    "vitepress": "1.6.4",
    "vitest": "^0.25.2",
    "vue": "^3.2.45"
  },
  "dependencies": {
    "core-js": "^3.26.1",
    "dotenv": "^17.3.1",
    "node-telegram-bot-api": "^0.66.0",
    "terser": "^5.16.0"
  }
}